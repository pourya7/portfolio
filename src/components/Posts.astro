---
interface BlogPost {
    id: string;
    title: string;
    description: string;
    pubDate: string;
    externalUrl?: string;
}

interface Props {
    posts: BlogPost[];
}

const { posts } = Astro.props;
const featured = posts[0];
const rest = posts.slice(1, 3);
---

<section class="container mx-auto">
    <h2 class="text-3xl font-bold mb-4 text-center">Blog</h2>
    <div
        class="grid grid-cols-1 gap-x-8 gap-y-8 lg:grid-cols-2 xl:grid-cols-2 mt-16"
    >
        {
            featured && (
                <a
                    href={`/blog/${featured.id}`}
                    class="block no-underline text-inherit hover:opacity-80 transition-opacity"
                >
                    <article>
                        <time class="block text-gray-600 dark:text-gray-400">
                            {new Date(featured.pubDate).toLocaleDateString(
                                "en-US",
                                {
                                    year: "numeric",
                                    month: "short",
                                    day: "numeric",
                                },
                            )}
                        </time>
                        <h2 class="mt-2 text-gray-800 dark:text-gray-100 md:text-2xl lg:text-4xl font-bold">
                            {featured.title}
                        </h2>
                        <p class="mt-4 text-lg line-clamp-3 sm:text-sm text-gray-800 dark:text-gray-200">
                            {featured.description}
                        </p>
                        <div class="flex mt-4">
                            <span class="text-md font-medium text-blue-500 dark:text-blue-400">
                                Continue reading{" "}
                                <span aria-hidden="true">→</span>
                            </span>
                        </div>
                    </article>
                </a>
            )
        }
        <div class="grid grid-cols-1 gap-y-8">
            {
                rest.map((post, index) => (
                    <>
                        {index > 0 && (
                            <div class="border-t-2 border-gray-200 dark:border-gray-800 hidden lg:block xl:block" />
                        )}
                        <a
                            href={`/blog/${post.id}`}
                            class="block no-underline text-inherit hover:opacity-80 transition-opacity"
                        >
                            <article>
                                <time class="block text-gray-600 dark:text-gray-400">
                                    {new Date(post.pubDate).toLocaleDateString(
                                        "en-US",
                                        {
                                            year: "numeric",
                                            month: "short",
                                            day: "numeric",
                                        },
                                    )}
                                </time>
                                <h2 class="mt-2 text-gray-800 dark:text-gray-100 md:text-2xl font-bold">
                                    {post.title}
                                </h2>
                                <p class="mt-4 text-lg line-clamp-3 sm:text-sm text-gray-800 dark:text-gray-200">
                                    {post.description}
                                </p>
                                <div class="flex mt-4">
                                    <span class="text-md font-medium text-blue-500 dark:text-blue-400">
                                        Continue reading{" "}
                                        <span aria-hidden="true">→</span>
                                    </span>
                                </div>
                            </article>
                        </a>
                    </>
                ))
            }
        </div>
    </div>
    <div class="text-center mt-12">
        <a
            href="/blog"
            class="inline-block bg-blue-500 text-white px-6 py-2 rounded hover:bg-blue-600 transition-colors font-medium"
        >
            View all posts →
        </a>
    </div>
</section>
