---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StructuredData from "../components/StructuredData.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  /** Absolute URL or /public-relative path for Open Graph image (1200×630 px) */
  image?: string;
  /** Set to 'article' on blog posts */
  ogType?: "website" | "article";
  /** ISO string or Date — for article:published_time */
  pubDate?: Date;
  updatedDate?: Date;
}

const {
  title = "Pourya Dashtegoli Pour | Product Engineer | AI Engineer | Full-Stack",
  description = "Senior Product Engineer, AI Engineer, and Full-Stack developer with 10+ years of experience building high-performance web apps and AI-native products.",
  canonicalUrl = Astro.url.href,
  image = "/img/hero.jpg",
  ogType = "website",
  pubDate,
  updatedDate,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const ogImage = image.startsWith("http") ? image : `${siteUrl}${image}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Pourya Dashtegoli Pour" />
    {
      ogType === "article" && pubDate && (
        <meta
          property="article:published_time"
          content={pubDate.toISOString()}
        />
      )
    }
    {
      ogType === "article" && updatedDate && (
        <meta
          property="article:modified_time"
          content={updatedDate.toISOString()}
        />
      )
    }

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title="Pourya Dashtegoli Pour's Blog"
      href="/rss.xml"
    />
    <title>{title}</title>

    <!-- Structured data (JSON-LD) -->
    <StructuredData
      type={ogType === "article" ? "BlogPosting" : "WebSite"}
      {title}
      {description}
      {canonicalUrl}
      {pubDate}
      {updatedDate}
      image={ogImage}
    />
    <style>
      #toasty {
        position: fixed;
        width: 100px;
        height: 100px;
        bottom: 0;
        right: -100px;
        transition: 500ms;
        background: url("/img/toasty.png");
        background-repeat: no-repeat;
        background-position: center;
        background-size: 100px;
      }

      #planet-cursor:hover {
        cursor:
          url(data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAABMAAAAPCAMAAAAxmgQeAAAACVBMVEX///8AAAD///9+749PAAAAAXRSTlMAQObYZgAAAD5JREFUGNN1j9EKADAIAnP//9GjFq6w7iU4DNRsB06cb44TJ+UzYUcniqnqoA6ag/62JhjKIU0rxx1lKveuXJ5UAQs/G/2vAAAAAElFTkSuQmCC),
          auto;
      }
    </style>
  </head>
  <body
    class="bg-white dark:bg-gray-900 text-gray-900 dark:text-white flex flex-col min-h-screen"
  >
    <div class="flex-grow">
      <Header />
      <slot />
      <Footer />
      <div id="toasty"></div>
    </div>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const keystrokeDelay = 1000;
        let state: any = { buffer: [], lastKeyTime: Date.now() };
        document.addEventListener("keydown", (event) => {
          const key = event.key;
          const currentTime = Date.now();
          let buffer;
          if (currentTime - state.lastKeyTime > keystrokeDelay) {
            buffer = [key];
          } else {
            buffer = [...state.buffer, key];
          }
          state = { buffer, lastKeyTime: currentTime };
          const userInput = buffer.join("");
          const code =
            "ArrowLeftArrowDownArrowLeftArrowRightArrowDownArrowRightArrowLeftArrowLeftArrowRightArrowRight";
          if (code === userInput) {
            const toastyEl = document.getElementById("toasty");
            if (!toastyEl) return;
            toastyEl.style.right = "0";
            setTimeout(() => {
              toastyEl.style.right = "-100px";
            }, 1000);
          }
        });
      });
    </script>
  </body>
</html>
